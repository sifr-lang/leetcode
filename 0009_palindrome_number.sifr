# LeetCode 9: Palindrome Number

def isPalindrome(x: int) -> bool:
    if x < 0:
        return False
    rev: int = 0
    original: int = x
    while x > 0:
        rev = rev * 10 + x % 10
        x = x // 10
    return original == rev

def main():
    assert str(isPalindrome(121)) == 'true'
    assert str(isPalindrome(-121)) == 'false'
    assert str(isPalindrome(10)) == 'false'
    assert str(isPalindrome(0)) == 'true'
    assert str(isPalindrome(12321)) == 'true'

