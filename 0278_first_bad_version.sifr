# LeetCode 278: First Bad Version

def isBadVersion(version: int) -> bool:
    return version >= 4

def firstBadVersion(n: int) -> int:
    l, r = 1, n
    while l < r:
        v = (l + r) // 2
        if isBadVersion(v):
            r = v
        else:
            l = v + 1
    return l

def main():
    assert firstBadVersion(5) == 4
    assert firstBadVersion(4) == 4
