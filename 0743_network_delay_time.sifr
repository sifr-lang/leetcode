# LeetCode 743: Network Delay Time

from sifr.heapq import heappush, heappop

def networkDelayTime(times: list[list[int]], n: int, k: int) -> int:
    if n <= 0 or k <= 0 or k > n:
        return -1

    max_weight = 0
    for edge in times:
        if len(edge) < 3:
            continue
        w0 = edge[2]
        if w0 is not None:
            weight = w0
            if weight > max_weight:
                max_weight = weight

    edge_base = max_weight + 1
    if edge_base <= 0:
        edge_base = 1

    edges: dict[int, list[int]] = {}
    for edge in times:
        if len(edge) < 3:
            continue
        u0 = edge[0]
        v0 = edge[1]
        w0 = edge[2]
        if u0 is not None and v0 is not None and w0 is not None:
            if u0 <= 0 or u0 > n or v0 <= 0 or v0 > n:
                continue
            encoded = v0 * edge_base + w0
            bucket = edges.get(u0)
            if bucket is None:
                edges[u0] = [encoded]
            else:
                edges[u0] = bucket + [encoded]

    visit: set[int] = set()
    node_base = n + 1
    heap: list[int] = []
    heappush(heap, k)
    t = 0

    while heap:
        top = heappop(heap)
        if top is not None:
            w1 = top // node_base
            n1 = top % node_base
            if n1 in visit:
                continue
            visit.add(n1)
            t = w1

            neighbors = edges.get(n1)
            if neighbors is not None:
                for encoded_edge in neighbors:
                    n2 = encoded_edge // edge_base
                    w2 = encoded_edge % edge_base
                    if n2 not in visit:
                        heappush(heap, (w1 + w2) * node_base + n2)
        else:
            break

    return t if len(visit) == n else -1

def main():
    assert networkDelayTime([[2, 1, 1], [2, 3, 1], [3, 4, 1]], 4, 2) == 2
    assert networkDelayTime([[1, 2, 1]], 2, 1) == 1
    assert networkDelayTime([[1, 2, 1]], 2, 2) == -1
