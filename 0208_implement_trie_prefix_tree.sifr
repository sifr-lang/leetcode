# LeetCode 208: Implement Trie Prefix Tree
from helpers.trie import Trie

def main():
    obj = Trie()
    obj.insert('apple')
    assert obj.search('apple') == True
    assert obj.search('app') == False
    assert obj.startsWith('app') == True
    obj.insert('app')
    assert obj.search('app') == True
