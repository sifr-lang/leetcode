# LeetCode 1929: Concatenation of Array

def getConcatenation(nums: list[int]) -> list[int]:
    ans: list[int] = []
    for i in range(2):
        for j in range(len(nums)):
            ans.append(nums[j])
    return ans

def main():
    assert str(getConcatenation([1, 2, 1])) == '[1, 2, 1, 1, 2, 1]'
    assert str(getConcatenation([1, 3, 2, 1])) == '[1, 3, 2, 1, 1, 3, 2, 1]'

