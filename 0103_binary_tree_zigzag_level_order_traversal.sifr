# LeetCode 103: Binary Tree Zigzag Level Order Traversal
from helpers.tree_node import TreeNode, treeToString

def nodeValue(node: TreeNode | None) -> int:
    if node is None:
        return 0
    value = node.val
    if value is None:
        return 0
    return value
def zigzagLevelOrder(own root: TreeNode | None) -> list[list[int]]:
    if root is None:
        return []
    result: list[list[int]] = []
    zigzagDirection: int = 1
    q: list[TreeNode] = []
    q.append(root)
    while q:
        level: list[int] = []
        queueLength: int = len(q)
        for i in range(queueLength):
            node = q.pop(0)
            level.append(nodeValue(node))
            left_child = node.left
            if left_child is not None:
                q.append(left_child)
            right_child = node.right
            if right_child is not None:
                q.append(right_child)
        if zigzagDirection == -1:
            level.reverse()
        result = result + [level]
        zigzagDirection *= -1
    return result

def main():
    assert zigzagLevelOrder(TreeNode(3, TreeNode(9, None, None), TreeNode(20, TreeNode(15, None, None), TreeNode(7, None, None)))) == [[3], [20, 9], [15, 7]]
    assert zigzagLevelOrder(TreeNode(1, None, None)) == [[1]]
    assert len(zigzagLevelOrder(None)) == 0
