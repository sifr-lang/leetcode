# LeetCode 1046: Last Stone Weight

def lastStoneWeight(mut stones: list[int]) -> int:
    while len(stones) > 1:
        stones.sort()
        y = stones.pop()
        x = stones.pop()
        if y > x:
            stones.append(y - x)

    if len(stones) == 0:
        return 0
    return stones.pop()

def main():
    assert lastStoneWeight([2, 7, 4, 1, 8, 1]) == 1
    assert lastStoneWeight([1]) == 1
