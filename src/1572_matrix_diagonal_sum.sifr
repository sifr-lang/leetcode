# LeetCode 1572: Matrix Diagonal Sum

def _nz_int(value: int | None) -> int:
    if value is None:
        return 0
    return value

def diagonalSum(mat: list[list[int]]) -> int:
    n = len(mat)
    total = 0
    for i in range(n):
        total += _nz_int(mat[i][i])
        j = n - 1 - i
        if j != i:
            total += _nz_int(mat[i][j])
    return total

def main():
    assert str(diagonalSum([[1, 2, 3], [4, 5, 6], [7, 8, 9]])) == '25'
