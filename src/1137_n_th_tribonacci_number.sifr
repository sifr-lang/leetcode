# LeetCode 1137: N Th Tribonacci Number


def tribonacci(n: int) -> int:
    if n == 0:
        return 0
    if n == 1:
        return 1
    if n == 2:
        return 1

    a, b, c = 0, 1, 1
    i = 3
    while i <= n:
        nxt = a + b + c
        a = b
        b = c
        c = nxt
        i += 1
    return c

def main():
    assert str(tribonacci(4)) == '4'
    assert str(tribonacci(25)) == '1389537'
