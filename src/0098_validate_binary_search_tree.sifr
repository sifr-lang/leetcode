# LeetCode 98: Validate Binary Search Tree
from helpers.tree_node import TreeNode, treeToString
def isValidBST(root: TreeNode | None) -> bool:
    LIMIT = 1 << 60

    def valid(node: TreeNode | None, left: int, right: int) -> bool:
        if not node:
            return True
        if not (left < node.val < right):
            return False

        return valid(node.left, left, node.val) and valid(
            node.right, node.val, right
        )

    return valid(root, -LIMIT, LIMIT)

def main():
    assert isValidBST(TreeNode(2, TreeNode(1, None, None), TreeNode(3, None, None))) == True
    assert isValidBST(TreeNode(5, TreeNode(1, None, None), TreeNode(4, TreeNode(3, None, None), TreeNode(6, None, None)))) == False
