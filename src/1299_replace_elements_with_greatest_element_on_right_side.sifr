# LeetCode 1299: Replace Elements With Greatest Element On Right Side

def replaceElements(own mut arr: list[int]) -> list[int]:
    rightMax = -1
    for i in range(len(arr) -1, -1, -1):
        current = arr[i]
        newMax = max(rightMax, current)
        arr[i] = rightMax
        rightMax = newMax
    return arr

def main():
    assert str(replaceElements([17,18,5,4,6,1])) == '[18, 6, 6, 6, 1, -1]'
