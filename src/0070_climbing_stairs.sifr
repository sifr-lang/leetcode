# LeetCode 70: Climbing Stairs

def climbStairs(n: int) -> int:
    if n <= 2:
        return n
    a: int = 1
    b: int = 2
    for i in range(3, n + 1):
        temp: int = b
        b = a + b
        a = temp
    return b

def main():
    assert str(climbStairs(1)) == '1'
    assert str(climbStairs(2)) == '2'
    assert str(climbStairs(3)) == '3'
    assert str(climbStairs(5)) == '8'
    assert str(climbStairs(10)) == '89'

