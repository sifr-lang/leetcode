# LeetCode 35: Search Insert Position

def searchInsert(nums: list[int], target: int) -> int:
    # O(log n) and O(1)
    
    
    low, high = 0, len(nums)
    while low<high:
        mid = low +(high - low) // 2
        if target > nums[mid]:
            low = mid + 1
        else:
            high = mid
    return low

def main():
    assert str(searchInsert([1,3,5,6], 5)) == '2'
    assert str(searchInsert([1,3,5,6], 2)) == '1'
    assert str(searchInsert([1,3,5,6], 7)) == '4'


