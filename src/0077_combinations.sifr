# LeetCode 77: Combinations

def combine(n: int, k: int) -> list[list[int]]:
    res = []
    def helper(start: int, comb: list[int]):
        if len(comb) == k:
            res.append(comb.copy())
            return
        for i in range(start, n+1):
            comb.append(i)
            helper(i+1, comb)
            comb.pop()
    helper(1, [])
    return res

def main():
    assert str(combine(4, 2)) == '[[1, 2], [1, 3], [1, 4], [2, 3], [2, 4], [3, 4]]'

