# LeetCode 392: Is Subsequence

def isSubsequence(s: str, t: str) -> bool:
    si: int = 0
    ti: int = 0
    while si < len(s) and ti < len(t):
        if s[si] == t[ti]:
            si += 1
        ti += 1
    return si == len(s)

def main():
    assert str(isSubsequence("abc", "ahbgdc")) == 'true'
    assert str(isSubsequence("axc", "ahbgdc")) == 'false'
    assert str(isSubsequence("", "ahbgdc")) == 'true'
    assert str(isSubsequence("ace", "abcde")) == 'true'

