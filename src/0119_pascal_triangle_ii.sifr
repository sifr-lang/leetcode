# LeetCode 119: Pascal Triangle Ii

def getRow(rowIndex: int) -> list[int]:
    result: list[int] = []
    coeff: int = 1
    for k in range(rowIndex + 1):
        result.append(coeff)
        numerator: int = rowIndex - k
        denominator: int = k + 1
        coeff = (coeff * numerator) // denominator
    return result

def main():
    assert str(getRow(3)) == '[1, 3, 3, 1]'
    assert str(getRow(0)) == '[1]'

