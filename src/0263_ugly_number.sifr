# LeetCode 263: Ugly Number

def isUgly(n: int) -> bool:
    value = n
    if value <= 0:
        return False
    
    for p in [2, 3, 5]:
        while value % p == 0:
            value = value // p
    return value == 1

def main():
    assert str(isUgly(6)) == 'true'
    assert str(isUgly(1)) == 'true'
    assert str(isUgly(14)) == 'false'


