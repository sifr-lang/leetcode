# LeetCode 43: Multiply Strings

def parseDigit(ch: str) -> int:
    if ch == "0":
        return 0
    if ch == "1":
        return 1
    if ch == "2":
        return 2
    if ch == "3":
        return 3
    if ch == "4":
        return 4
    if ch == "5":
        return 5
    if ch == "6":
        return 6
    if ch == "7":
        return 7
    if ch == "8":
        return 8
    if ch == "9":
        return 9
    return -1

def parseNumber(s: str) -> int:
    value = 0
    i = 0
    while i < len(s):
        ch = s[i]
        d = parseDigit(ch)
        if d < 0:
            return -1
        value = value * 10 + d
        i += 1
    return value

def multiply(num1: str, num2: str) -> str:
    n1 = parseNumber(num1)
    n2 = parseNumber(num2)
    if n1 < 0 or n2 < 0:
        return "0"
    return str(n1 * n2)

def main():
    assert str(multiply("2", "3")) == '6'
    assert str(multiply("123", "456")) == '56088'
