# LeetCode 1137: N Th Tribonacci Number

Memo: dict[int, int] = {}


def tribonacci(n: int) -> int:
    if n in Memo:
        return Memo[n]
    if n == 0:
        return 0
    if n == 1:
        return 1
    if n == 2:
        return 1
    Memo[n] = (
        tribonacci(n - 1) + tribonacci(n - 2) + tribonacci(n - 3)
    )
    return Memo[n]

def main():
    assert str(tribonacci(4)) == '4'
    assert str(tribonacci(25)) == '1389537'

