# LeetCode 896: Monotonic Array

def isMonotonic(nums: list[int]) -> bool:
    increasing = decreasing = True
    
    for i in range(len(nums) - 1):
        if nums[i] > nums[i + 1]:
            increasing = False
        if nums[i] < nums[i + 1]:
            decreasing = False
    
    return increasing or decreasing

def main():
    assert str(isMonotonic([1,2,2,3])) == 'true'
    assert str(isMonotonic([6,5,4,4])) == 'true'
    assert str(isMonotonic([1,3,2])) == 'false'


