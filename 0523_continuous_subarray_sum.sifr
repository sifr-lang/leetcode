# LeetCode 523: Continuous Subarray Sum

def checkSubarraySum(nums: list[int], k: int) -> bool:
    hashmap = {}
    hashmap[0]=-1
    summ=0
    for i,j in enumerate(nums):
        summ+=j
        if summ%k in hashmap.keys():
            if i-hashmap[summ%k]>=2:
                return True
            else:
                continue
        hashmap[summ%k]=i
    return False

def main():
    assert str(checkSubarraySum([23,2,4,6,7], 6)) == 'true'


