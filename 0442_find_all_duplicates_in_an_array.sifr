# LeetCode 442: Find All Duplicates In An Array

def findDuplicates(nums: list[int]) -> list[int]:
    seen: set[int] = set()
    res: list[int] = []
    for n in nums:
        if n in seen:
            res.append(n)
        else:
            seen.add(n)
    return res

def main():
    assert findDuplicates([4, 3, 2, 7, 8, 2, 3, 1]) == [2, 3]
    assert findDuplicates([1, 1, 2]) == [1]
    assert findDuplicates([1]) == []
