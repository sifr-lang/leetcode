# LeetCode 2864: Maximum Odd Binary Number

def maximumOddBinaryNumber(s: str) -> str:
    count = 0
    for c in s:
        if c == "1":
            count += 1
    
    return (count - 1) * "1" + (len(s) - count) * "0" + "1"

def main():
    assert str(maximumOddBinaryNumber("010")) == '001'
    assert str(maximumOddBinaryNumber("0101")) == '1001'

