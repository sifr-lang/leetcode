# LeetCode 127: Word Ladder

def ladderLength(beginWord: str, endWord: str, mut wordList: list[str]) -> int:
    if endWord not in wordList:
        return 0

    nei: dict[str, list[str]] = {}
    wordList.append(str(beginWord))
    for word in wordList:
        for j in range(len(word)):
            pattern = word[:j] + "*" + word[j + 1 :]
            existing = nei.get(pattern)
            if existing is None:
                nei[pattern] = [str(word)]
            else:
                nei[pattern] = existing + [str(word)]

    visit: set[str] = set([str(beginWord)])
    q: list[str] = [str(beginWord)]
    res = 1
    while q:
        level_size = len(q)
        for i in range(level_size):
            word = q.pop(0)
            if word == endWord:
                return res
            for j in range(len(word)):
                pattern = word[:j] + "*" + word[j + 1 :]
                neighbors = nei.get(pattern)
                if neighbors is not None:
                    for neiWord in neighbors:
                        if neiWord not in visit:
                            visit.add(str(neiWord))
                            q.append(str(neiWord))
        res += 1
    return 0

def main():
    assert ladderLength('hit', 'cog', ['hot', 'dot', 'dog', 'lot', 'log', 'cog']) == 5
    assert ladderLength('hit', 'cog', ['hot', 'dot', 'dog', 'lot', 'log']) == 0
