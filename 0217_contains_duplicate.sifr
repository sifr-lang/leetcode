# LeetCode 217: Contains Duplicate

def containsDuplicate(nums: list[int]) -> bool:
    hashset = set()

    for n in nums:
        if n in hashset:
            return True
        hashset.add(n)
    return False

def main():
    assert str(containsDuplicate([1,2,3,1])) == 'true'
    assert str(containsDuplicate([1,2,3,4])) == 'false'


