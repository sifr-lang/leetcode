# LeetCode 344: Reverse String

def reverseString(mut s: list[str]) -> None:
    
    l = 0
    r = len(s) - 1
    while l < r:
        tmp = s[l]
        s[l] = s[r]
        s[r] = tmp
        l += 1
        r -= 1

def main():
    arg0 = ['h', 'e', 'l', 'l', 'o']
    _result = reverseString(arg0)
    assert arg0 == ['o', 'l', 'l', 'e', 'h']
    arg0 = ['H', 'a', 'n', 'n', 'a', 'h']
    _result = reverseString(arg0)
    assert arg0 == ['h', 'a', 'n', 'n', 'a', 'H']
