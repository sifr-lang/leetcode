# LeetCode 125: Valid Palindrome

def isPalindrome(s: str) -> bool:
    new = ''
    for a in s:
        if a.isalpha() or a.isdigit():
            new += a.lower()
    return (new == new[::-1])

def main():
    assert str(isPalindrome("A man, a plan, a canal: Panama")) == 'true'
    assert str(isPalindrome("race a car")) == 'false'


