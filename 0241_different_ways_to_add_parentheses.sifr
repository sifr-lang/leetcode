# LeetCode 241: Different Ways To Add Parentheses

def diffWaysToCompute(s: str) -> list[int]:
    def f(s):
        res = []
        for i, c in enumerate(s):
            if c in '+-*':
                for l in f(s[:i]):
                    for r in f(s[i + 1:]):
                        res.append(eval(f'{l}{c}{r}'))
        
        return res or [int(s)]
    return f(s)

def main():
    assert str(diffWaysToCompute("2-1-1")) == '[0, 2]'


