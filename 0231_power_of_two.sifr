# LeetCode 231: Power Of Two

def isPowerOfTwo(n: int) -> bool:
    x = 1
    while x < n:
        x *= 2
    return x == n        

# Bit manipulation

def isPowerOfTwo(n: int) -> bool:
    return n > 0 and (n & (n - 1)) == 0

# Bit manipulation

def isPowerOfTwo(n: int) -> bool:
    return n > 0 and ((1 << 30) % n) == 0

def main():
    assert str(isPowerOfTwo(1)) == 'true'
    assert str(isPowerOfTwo(16)) == 'true'
    assert str(isPowerOfTwo(3)) == 'false'


