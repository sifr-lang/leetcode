# LeetCode 338: Counting Bits

def countBits(n: int) -> list[int]:
    dp = [0] * (n + 1)
    offset = 1

    for i in range(1, n + 1):
        if offset * 2 == i:
            offset = i
        dp[i] = 1 + dp[i - offset]
    return dp

def main():
    assert str(countBits(2)) == '[0, 1, 1]'
    assert str(countBits(5)) == '[0, 1, 1, 2, 1, 2]'

