# LeetCode 252: Meeting Rooms

def canAttendMeetings(mut intervals: list[list[int]]) -> bool:
    intervals.sort()

    for i in range(1, len(intervals)):
        i1 = intervals[i - 1]
        i2 = intervals[i]

        if i1[1] > i2[0]:
            return False
    return True

def main():
    assert str(canAttendMeetings([[0,30],[5,10],[15,20]])) == 'false'
    assert str(canAttendMeetings([[7,10],[2,4]])) == 'true'
