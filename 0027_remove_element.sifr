# LeetCode 27: Remove Element

def removeElement(mut nums: list[int], val: int) -> int:
    k = 0
    for i in range(len(nums)):
        if nums[i] != val:
            nums[k] = nums[i]
            k += 1
    return k

def main():
    assert str(removeElement([3,2,2,3], 3)) == '2'
    assert str(removeElement([0,1,2,2,3,0,4,2], 2)) == '5'

