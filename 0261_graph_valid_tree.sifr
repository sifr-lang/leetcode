def validTreeDsu(n: int, edges: list[list[int]]) -> bool:
    if n == 0:
        return True

    parents = [i for i in range(n)]
    ranks = [1] * n
    components = n

    def find(node: int) -> int:
        parent0 = parents[node]
        if parent0 is None:
            return node
        parent = parent0
        if parent == node:
            return node
        root = find(parent)
        parents[node] = root
        return root

    for edge in edges:
        a0 = edge[0]
        b0 = edge[1]
        a = 0
        b = 0
        if a0 is not None and b0 is not None:
            a = a0
            b = b0
        else:
            continue

        rootA = find(a)
        rootB = find(b)
        if rootA == rootB:
            return False

        rankA0 = ranks[rootA]
        rankB0 = ranks[rootB]
        rankA = 0
        rankB = 0
        if rankA0 is not None and rankB0 is not None:
            rankA = rankA0
            rankB = rankB0
        else:
            continue

        if rankA < rankB:
            parents[rootA] = rootB
        elif rankA > rankB:
            parents[rootB] = rootA
        else:
            parents[rootB] = rootA
            ranks[rootA] = rankA + 1
        components -= 1

    return components == 1

# Canonical entrypoint for this fixture.
def validTree(n: int, edges: list[list[int]]) -> bool:
    return validTreeDsu(n, edges)

def main():
    assert validTree(5, [[0, 1], [0, 2], [0, 3], [1, 4]]) == True
    assert validTree(5, [[0, 1], [1, 2], [2, 3], [1, 3], [1, 4]]) == False
    assert validTreeDsu(5, [[0, 1], [0, 2], [0, 3], [1, 4]]) == True
    assert validTreeDsu(5, [[0, 1], [1, 2], [2, 3], [1, 3], [1, 4]]) == False
