# LeetCode 100: Same Tree
from helpers.tree_node import TreeNode, treeToString
def isSameTree(p: TreeNode | None, q: TreeNode | None) -> bool:
    return treeToString(p) == treeToString(q)

def main():
    assert isSameTree(TreeNode(1, None, None), TreeNode(1, None, None)) == True
    assert isSameTree(TreeNode(1, None, None), None) == False
    assert isSameTree(None, None) == True
