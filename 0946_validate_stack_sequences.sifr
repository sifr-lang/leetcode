# LeetCode 946: Validate Stack Sequences

def validateStackSequences(pushed: list[int], popped: list[int]) -> bool:
    i = 0
    stack = []
    for n in pushed:
        stack.append(n)
        while i < len(popped) and stack and popped[i] == stack[-1]:
            stack.pop()
            i += 1

    return len(stack) == 0

def main():
    assert str(validateStackSequences([1,2,3,4,5], [4,5,3,2,1])) == 'true'
    assert str(validateStackSequences([1,2,3,4,5], [4,3,5,1,2])) == 'false'
