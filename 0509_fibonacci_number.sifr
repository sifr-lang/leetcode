# LeetCode 509: Fibonacci Number

def fib(n: int) -> int:
    if n <= 1:
        return n
    a: int = 0
    b: int = 1
    for i in range(2, n + 1):
        temp: int = b
        b = a + b
        a = temp
    return b

def main():
    assert str(fib(0)) == '0'
    assert str(fib(1)) == '1'
    assert str(fib(2)) == '1'
    assert str(fib(3)) == '2'
    assert str(fib(4)) == '3'
    assert str(fib(10)) == '55'
    assert str(fib(20)) == '6765'

